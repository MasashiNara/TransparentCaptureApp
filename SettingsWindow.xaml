<Window x:Class="TransparentCaptureApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="設定"
        Width="720"
        Height="680"
        MinWidth="640"
        MinHeight="560"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="保存先フォルダ" VerticalAlignment="Center" Margin="0,0,8,8" />
                <TextBox x:Name="SaveDirectoryTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,8,8" />
                <Button Grid.Row="0" Grid.Column="2" Content="参照" Width="72" Margin="0,0,0,8" Click="BrowseSaveDirectory_Click" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="LLMプロバイダ" VerticalAlignment="Center" Margin="0,0,8,8" />
                <ComboBox x:Name="ProviderComboBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8">
                    <ComboBoxItem Content="OpenAi" />
                    <ComboBoxItem Content="Anthropic" />
                    <ComboBoxItem Content="Ollama" />
                    <ComboBoxItem Content="LlamaCpp" />
                </ComboBox>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="OpenAI APIキー" VerticalAlignment="Center" Margin="0,0,8,8" />
                <PasswordBox x:Name="OpenAiApiKeyPasswordBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" />

                <TextBlock Grid.Row="3" Grid.Column="0" Text="OpenAIモデル名" VerticalAlignment="Center" Margin="0,0,8,8" />
                <TextBox x:Name="OpenAiModelTextBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" />

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Anthropic APIキー" VerticalAlignment="Center" Margin="0,0,8,8" />
                <PasswordBox x:Name="AnthropicApiKeyPasswordBox" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" />

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Anthropicモデル名" VerticalAlignment="Center" Margin="0,0,8,8" />
                <TextBox x:Name="AnthropicModelTextBox" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" />

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Ollama接続URL" VerticalAlignment="Center" Margin="0,0,8,8" />
                <TextBox x:Name="OllamaUrlTextBox" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" />

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Ollamaモデル名" VerticalAlignment="Center" Margin="0,0,8,8" />
                <TextBox x:Name="OllamaModelTextBox" Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" />

                <TextBlock Grid.Row="8" Grid.Column="0" Text="llama.cpp接続URL" VerticalAlignment="Center" Margin="0,0,8,8" />
                <TextBox x:Name="LlamaCppUrlTextBox" Grid.Row="8" Grid.Column="1" Margin="0,0,8,8" />
                <Button Grid.Row="8" Grid.Column="2" Content="画像対応チェック" Width="120" Margin="0,0,0,8" Click="CheckLlamaCppVisionButton_Click" />

                <TextBlock Grid.Row="9" Grid.Column="0" Text="llama.cppモデル名" VerticalAlignment="Center" Margin="0,0,8,8" />
                <TextBox x:Name="LlamaCppModelTextBox" Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,8" />

                <TextBlock Grid.Row="10" Grid.Column="0" Text="文字起こしプロンプト" VerticalAlignment="Top" Margin="0,0,8,8" />
                <TextBox x:Name="PromptTextBox"
                         Grid.Row="10"
                         Grid.Column="1"
                         Grid.ColumnSpan="2"
                         Height="120"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,8" />

                <CheckBox x:Name="SaveCaptureImageCheckBox"
                          Grid.Row="11"
                          Grid.Column="1"
                          Grid.ColumnSpan="2"
                          Content="キャプチャ画像を保存する"
                          Margin="0,0,0,8" />
                <CheckBox x:Name="DeleteImageAfterSuccessCheckBox"
                          Grid.Row="12"
                          Grid.Column="1"
                          Grid.ColumnSpan="2"
                          Content="文字起こし成功後に画像を削除する"
                          Margin="0,0,0,8" />
                <CheckBox x:Name="SaveTranscriptTextCheckBox"
                          Grid.Row="13"
                          Grid.Column="1"
                          Grid.ColumnSpan="2"
                          Content="テキストファイルを保存する"
                          Margin="0,0,0,8" />
                <CheckBox x:Name="OpenTranscriptAfterSaveCheckBox"
                          Grid.Row="14"
                          Grid.Column="1"
                          Grid.ColumnSpan="2"
                          Content="テキスト保存後に自動で開く"
                          Margin="0,0,0,8" />

                <TextBlock Grid.Row="15" Grid.Column="0" Text="ログファイル保存先" VerticalAlignment="Center" Margin="0,0,8,8" />
                <TextBox x:Name="LogFilePathTextBox" Grid.Row="15" Grid.Column="1" Margin="0,0,8,8" />
                <Button Grid.Row="15" Grid.Column="2" Content="参照" Width="72" Margin="0,0,0,8" Click="BrowseLogDirectory_Click" />
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="保存" Width="96" Margin="0,0,8,0" Click="SaveButton_Click" />
            <Button Content="キャンセル" Width="96" Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
